{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Profile information for talents and investors.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "role": { "type": "string", "enum": ["talent", "investor", "admin"], "description": "User role" },
        "bio": { "type": "string", "description": "Short bio" },
        "category": { "type": "string", "description": "Main category for talents" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "photoURL": { "type": "string", "format": "uri", "description": "Profile picture URL" },
        "whatsapp": { "type": "string", "description": "WhatsApp number" },
        "phone": { "type": "string", "description": "Phone number for OTP" },
        "location": { "type": "string", "description": "User location (City/State)" },
        "isFeatured": { "type": "boolean", "description": "Whether the talent is featured" },
        "isFounder": { "type": "boolean", "description": "Whether the user is a founder" },
        "isTalentOfTheWeek": { "type": "boolean", "description": "Whether the user is the talent of the week" },
        "isVerified": { "type": "boolean", "description": "General verification status" },
        "isEmailVerified": { "type": "boolean", "description": "Email verification status" },
        "isPhoneVerified": { "type": "boolean", "description": "Phone verification status" },
        "isInvestorVerified": { "type": "boolean", "description": "Investor KYC status" },
        "uniqueViewsCount": { "type": "integer", "description": "Number of unique visitors" },
        "interactionsCount": { "type": "integer", "description": "Number of interactions (clicks/messages)" },
        "kyc": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "country": { "type": "string" },
            "documentURL": { "type": "string" },
            "selfieURL": { "type": "string" },
            "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
            "rejectionReason": { "type": "string" },
            "submittedAt": { "type": "string", "format": "date-time" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" },
        "followers": { "type": "array", "items": { "type": "string" }, "description": "UIDs of followers" },
        "following": { "type": "array", "items": { "type": "string" }, "description": "UIDs of followed users" },
        "company": { "type": "string", "description": "Company/Organization for investors" },
        "investmentFocus": { "type": "array", "items": { "type": "string" }, "description": "Categories the investor is interested in" },
        "interests": { "type": "array", "items": { "type": "string" }, "description": "General interests/categories" },
        "viewedProjects": { "type": "array", "items": { "type": "string" }, "description": "IDs of recently viewed projects" },
        "status": { "type": "string", "enum": ["active", "suspended", "banned"], "description": "Account status" },
        "isBanned": { "type": "boolean", "description": "Whether the user is banned" },
        "banReason": { "type": "string", "description": "Reason for the ban" },
        "isSuspicious": { "type": "boolean", "description": "Whether the user is marked as suspicious" },
        "suspicionReason": { "type": "string", "description": "Reason for suspicion" },
        "reportCount": { "type": "integer", "description": "Number of reports received" },
        "messageCount": { "type": "integer", "description": "Total messages sent" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "dailyMessageCount": { "type": "integer" },
        "welcomeShown": { "type": "boolean", "description": "Whether the welcome message has been shown" },
        "portfolio": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["image", "video", "document"] },
              "title": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "description": { "type": "string" },
              "fileName": { "type": "string" },
              "fileSize": { "type": "number" },
              "mimeType": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Project": {
      "title": "Project/Work",
      "description": "A piece of work or portfolio item published by a talent.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Project ID" },
        "talentId": { "type": "string", "description": "UID of the talent who created this" },
        "talentName": { "type": "string", "description": "Name of the talent" },
        "talentEmail": { "type": "string", "description": "Email of the talent" },
        "talentLocation": { "type": "string", "description": "Location of the talent" },
        "title": { "type": "string", "description": "Project title" },
        "description": { "type": "string", "description": "Project description" },
        "category": { "type": "string", "description": "Project category" },
        "imageUrl": { "type": "string", "format": "uri", "description": "Project image URL" },
        "projectLink": { "type": "string", "format": "uri", "description": "External project link" },
        "likesCount": { "type": "integer", "description": "Number of likes" },
        "commentsCount": { "type": "integer", "description": "Number of comments" },
        "status": { "type": "string", "enum": ["published", "draft"], "description": "Publication status" },
        "rating": {
          "type": "object",
          "properties": {
            "average": { "type": "number", "description": "Average rating (1-5)" },
            "count": { "type": "integer", "description": "Number of ratings" },
            "total": { "type": "integer", "description": "Total sum of stars" },
            "ratedBy": { "type": "array", "items": { "type": "string" }, "description": "UIDs of users who rated" }
          }
        },
        "deadline": { "type": "string", "format": "date-time", "description": "Project deadline" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Publication date" }
      },
      "required": ["id", "talentId", "title", "description", "category"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat session between two users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantNames": { "type": "object" },
        "participantPhotos": { "type": "object" },
        "lastMessage": { "type": "string" },
        "acceptedBy": { "type": "array", "items": { "type": "string" }, "description": "UIDs of participants who accepted the chat" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A single chat message.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "conversationId", "senderId", "text"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhotoURL": { "type": "string", "format": "uri" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "userId", "userName", "text"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A user notification.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "recipientId": { "type": "string", "description": "UID of the user receiving the notification" },
        "senderId": { "type": "string", "description": "UID of the user who triggered the notification" },
        "senderName": { "type": "string", "description": "Name of the sender" },
        "senderPhotoURL": { "type": "string", "format": "uri", "description": "Photo URL of the sender" },
        "type": { "type": "string", "enum": ["rating", "like", "comment"] },
        "projectTitle": { "type": "string", "description": "Title of the project" },
        "projectId": { "type": "string", "description": "ID of the project" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "recipientId", "senderId", "senderName", "projectTitle", "projectId", "read"]
    },
    "Report": {
      "title": "User Report",
      "description": "A report against a user for misconduct.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterId": { "type": "string" },
        "reporterName": { "type": "string" },
        "targetId": { "type": "string" },
        "targetName": { "type": "string" },
        "type": { "type": "string", "enum": ["fraude", "pedido_dinheiro", "comportamento_suspeito", "outro"] },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved", "dismissed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "reporterId", "targetId", "type", "description"]
    },
    "AdminLog": {
      "title": "Admin Log",
      "description": "Log of administrative actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminId": { "type": "string" },
        "adminName": { "type": "string" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "targetName": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "adminId", "action", "details"]
    },
    "ErrorLog": {
      "title": "Error Log",
      "description": "Log of automatic application errors.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "UID of the user who encountered the error" },
        "userName": { "type": "string" },
        "errorMessage": { "type": "string" },
        "errorStack": { "type": "string" },
        "componentStack": { "type": "string" },
        "url": { "type": "string" },
        "userAgent": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "errorMessage", "timestamp"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "siteName": { "type": "string" },
        "siteDescription": { "type": "string" },
        "securityMessage": { "type": "string" },
        "allowNewRegistrations": { "type": "boolean" },
        "maintenanceMode": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["id", "siteName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Talent projects"
    },
    "/projects/{projectId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a project"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Chat conversations"
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a conversation"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "User misconduct reports"
    },
    "/admin_logs/{logId}": {
      "schema": "AdminLog",
      "description": "Administrative action logs"
    },
    "/error_logs/{logId}": {
      "schema": "ErrorLog",
      "description": "Automatic application error logs"
    },
    "/site_settings/{settingsId}": {
      "schema": "SiteSettings",
      "description": "Global site settings"
    }
  }
}
